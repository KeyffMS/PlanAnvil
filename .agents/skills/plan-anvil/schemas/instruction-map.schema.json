{
  "$defs": {
    "hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "next_action": {
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "type",
        "target"
      ],
      "type": "object"
    },
    "plan_id": {
      "pattern": "^PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}$",
      "type": "string"
    },
    "relative_path": {
      "minLength": 1,
      "not": {
        "pattern": "(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)|^(?:/|[A-Za-z]:[\\\\/]|\\\\\\\\)"
      },
      "type": "string"
    },
    "run_id": {
      "pattern": "^[0-9]{8}T[0-9]{6}Z_PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}_[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "sha": {
      "pattern": "^[0-9a-f]{40,64}$",
      "type": "string"
    },
    "stage_id": {
      "pattern": "^STAGE-[0-9]{2}[A-Z]?$",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    }
  },
  "$id": "https://keyffms.github.io/PlanAnvil/schemas/instruction-map.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "affected_paths": {
      "items": {
        "$ref": "#/$defs/relative_path"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "automatic_byte_limit": {
      "minimum": 1,
      "type": "integer"
    },
    "conflicts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "critical": {
            "type": "boolean"
          },
          "paths": {
            "items": {
              "$ref": "#/$defs/relative_path"
            },
            "minItems": 2,
            "type": "array"
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "paths",
          "critical",
          "resolution"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "fallback_filenames": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "affected_paths": {
            "items": {
              "$ref": "#/$defs/relative_path"
            },
            "minItems": 1,
            "type": "array"
          },
          "bytes": {
            "minimum": 1,
            "type": "integer"
          },
          "full_read": {
            "const": true
          },
          "path": {
            "$ref": "#/$defs/relative_path"
          },
          "precedence": {
            "minimum": 0,
            "type": "integer"
          },
          "safety_critical_rules": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "scope": {
            "$ref": "#/$defs/relative_path"
          },
          "sha256": {
            "$ref": "#/$defs/hash"
          },
          "truncation_risk": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "sha256",
          "bytes",
          "full_read",
          "scope",
          "precedence",
          "affected_paths",
          "truncation_risk",
          "safety_critical_rules"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "generated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "schema_version": {
      "const": "1.1.0"
    }
  },
  "required": [
    "schema_version",
    "generated_at",
    "affected_paths",
    "fallback_filenames",
    "automatic_byte_limit",
    "files",
    "conflicts"
  ],
  "title": "PlanAnvil instruction map",
  "type": "object"
}
