{
  "$defs": {
    "hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "relative_path": {
      "minLength": 1,
      "not": {
        "pattern": "(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)|^(?:/|[A-Za-z]:[\\\\/]|\\\\\\\\)"
      },
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    }
  },
  "$id": "https://keyffms.github.io/PlanAnvil/schemas/review-bundle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "excludes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "$ref": "#/$defs/relative_path"
          },
          "role": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "$ref": "#/$defs/hash"
          }
        },
        "required": [
          "path",
          "sha256",
          "role"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "purpose": {
      "const": "BLIND_PLAN_REVIEW"
    },
    "schema_version": {
      "const": "1.1.0"
    }
  },
  "required": [
    "schema_version",
    "created_at",
    "purpose",
    "excludes",
    "files"
  ],
  "title": "PlanAnvil blind review input bundle",
  "type": "object"
}
