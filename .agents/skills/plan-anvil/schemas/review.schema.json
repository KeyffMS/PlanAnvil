{
  "$defs": {
    "hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "next_action": {
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "type",
        "target"
      ],
      "type": "object"
    },
    "plan_id": {
      "pattern": "^PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}$",
      "type": "string"
    },
    "relative_path": {
      "minLength": 1,
      "not": {
        "pattern": "(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)|^(?:/|[A-Za-z]:[\\\\/]|\\\\\\\\)"
      },
      "type": "string"
    },
    "run_id": {
      "pattern": "^[0-9]{8}T[0-9]{6}Z_PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}_[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "sha": {
      "pattern": "^[0-9a-f]{40,64}$",
      "type": "string"
    },
    "stage_id": {
      "pattern": "^STAGE-[0-9]{2}[A-Z]?$",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    }
  },
  "$id": "https://keyffms.github.io/PlanAnvil/schemas/review.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "author_role": {
      "const": "plan-anvil-reviewer"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "findings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "pattern": "^FINDING-[0-9]{2,}$",
            "type": "string"
          },
          "severity": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "severity",
          "summary"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "inputs": {
      "additionalProperties": {
        "$ref": "#/$defs/hash"
      },
      "minProperties": 1,
      "type": "object"
    },
    "markdown_hash": {
      "$ref": "#/$defs/hash"
    },
    "report_type": {
      "const": "BLIND_PLAN_REVIEW"
    },
    "result": {
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "schema_version": {
      "const": "1.1.0"
    }
  },
  "required": [
    "schema_version",
    "report_type",
    "author_role",
    "created_at",
    "inputs",
    "result",
    "findings",
    "markdown_hash"
  ],
  "title": "PlanAnvil blind review sidecar",
  "type": "object"
}
