{
  "$defs": {
    "hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "next_action": {
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "type",
        "target"
      ],
      "type": "object"
    },
    "plan_id": {
      "pattern": "^PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}$",
      "type": "string"
    },
    "relative_path": {
      "minLength": 1,
      "not": {
        "pattern": "(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)|^(?:/|[A-Za-z]:[\\\\/]|\\\\\\\\)"
      },
      "type": "string"
    },
    "run_id": {
      "pattern": "^[0-9]{8}T[0-9]{6}Z_PG-[0-9]{8}-[0-9]{6}-[A-F0-9]{4}_[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "sha": {
      "pattern": "^[0-9a-f]{40,64}$",
      "type": "string"
    },
    "stage_id": {
      "pattern": "^STAGE-[0-9]{2}[A-Z]?$",
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string"
    }
  },
  "$id": "https://keyffms.github.io/PlanAnvil/schemas/compliance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "evidence": {
            "items": {
              "$ref": "#/$defs/relative_path"
            },
            "type": "array"
          },
          "id": {
            "pattern": "^CAP-[A-Z0-9-]+$",
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "VERIFIED",
              "DOCUMENTED",
              "FAILED",
              "BLOCKED",
              "UNKNOWN",
              "NOT_APPLICABLE"
            ]
          }
        },
        "required": [
          "id",
          "status",
          "required",
          "evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "codex": {
      "additionalProperties": false,
      "properties": {
        "hook_mode": {
          "enum": [
            "HOOKS_TRUSTED",
            "HOOKS_DISABLED",
            "HOOKS_UNTRUSTED",
            "HOOKS_UNAVAILABLE"
          ]
        },
        "model": {
          "type": "string"
        },
        "permission_mode": {
          "type": "string"
        },
        "project_trust": {
          "enum": [
            "TRUSTED",
            "UNTRUSTED",
            "UNKNOWN"
          ]
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "model",
        "permission_mode",
        "project_trust",
        "hook_mode"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "1.1.0"
    },
    "unsupported": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "verified_at": {
      "$ref": "#/$defs/timestamp"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "verified_at",
    "codex",
    "capabilities",
    "unsupported",
    "warnings"
  ],
  "title": "PlanAnvil compliance record",
  "type": "object"
}
